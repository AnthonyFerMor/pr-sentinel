# === Gemini API ===
# Obtener en: https://ai.google.dev → Google AI Studio → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
# Modelos de fallback separados por coma, en orden de preferencia.
# Se usan automáticamente si el modelo primario recibe 429 rate limit.
# gemini-2.5-flash tiene cuota separada en el free tier — muy recomendado.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash
GEMINI_MAX_RETRIES=4
GEMINI_THINKING_BUDGET=8192

# === GitHub ===
# Obtener en: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained
# Permisos necesarios (fine-grained): Contents (read), Pull requests (read & write), Issues (read & write)
PR_SENTINEL_GITHUB_TOKEN=your_github_pat_here

# === Auth (NextAuth.js) ===
# Secreto para firmar JWTs y encriptar cookies. Generá uno aleatorio:
# openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3001

# GitHub OAuth App — crear en: GitHub → Settings → Developer Settings → OAuth Apps
# Homepage URL: http://localhost:3001
# Callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# === App Config ===
NEXT_PUBLIC_APP_URL=http://localhost:3001

# === Webhooks (auto-review on PR open/update) ===
# Secreto compartido con el webhook de GitHub (Settings → Webhooks → Secret).
# Se usa para verificar la firma x-hub-signature-256 de cada entrega.
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# === Cron (revisión programada de PRs abiertos) ===
# Repos a escanear, separados por coma: "owner/repo,owner2/repo2"
CRON_REPOS=
# Tope de PRs revisados por corrida (evita exceder el timeout serverless).
CRON_MAX_PRS=5
# Bearer token que Vercel Cron envía en Authorization. Generá uno aleatorio.
CRON_SECRET=your_cron_secret_here
