# === Gemini API ===
# Obtener en: https://ai.google.dev → Google AI Studio → Get API Key
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
GEMINI_FALLBACK_MODELS=
GEMINI_MAX_RETRIES=4
GEMINI_THINKING_BUDGET=8192

# === GitHub ===
# Obtener en: GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained
# Permisos necesarios (fine-grained): Contents (read), Pull requests (read & write), Issues (read & write)
PR_SENTINEL_GITHUB_TOKEN=your_github_pat_here

# === App Config ===
NEXT_PUBLIC_APP_URL=http://localhost:3000
